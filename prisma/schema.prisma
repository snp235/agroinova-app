// Para trocar para PostgreSQL em produção, mude apenas:
//   provider = "postgresql"
//   url = env("DATABASE_URL")  <- no .env: DATABASE_URL="postgresql://user:pass@host:5432/agroinova"

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  role         String   @default("aluno") // aluno | professor | comunidade | agente
  school       String
  avatar       String?
  foodIndex    Int?
  isAdmin      Boolean  @default(false)
  status       String   @default("ativo") // ativo | inativo | desativado
  xp           Int      @default(0)
  coletas      Int      @default(0)
  streak       Int      @default(0)
  createdAt    DateTime @default(now())
  lastActive   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posts             Post[]
  organizedEvents   Event[]
  eventSuggestions  EventSuggestion[]
  postLikes         PostLike[]
  postSaves         PostSave[]
  eventInterests    EventInterest[]
  gardenMemberships GardenParticipant[]
  medals            UserMedal[]
  leafHistory       LeafEntry[]
  foodAnswers       FoodAnswer[]
  notifications     Notification[]
  reportsCreated    Report[] @relation("Reporter")
  reportsReviewed   Report[] @relation("Reviewer")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // post_identified | event_suggestion_approved | event_suggestion_rejected | post_reported_action | system
  title     String
  body      String
  linkTo    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Report {
  id           String    @id @default(cuid())
  postId       String
  reporterId   String
  reason       String
  reviewerId   String?
  resolution   String    @default("aberta") // aberta | mantida | removida | aviso
  reviewerNote String?
  createdAt    DateTime  @default(now())
  reviewedAt   DateTime?

  post     Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter User  @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer User? @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([resolution])
  @@index([postId])
}

model Post {
  id          String   @id @default(cuid())
  type        String   // coleta | informativo
  authorId    String
  title       String
  description String
  image       String?
  garden      String?
  category    String?  // ser-vivo | impacto-ambiental
  location    String?
  latitude    Float?
  longitude   Float?
  collectTime String?
  status      String   @default("ativo") // ativo | removida | pendente
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Dados científicos (somente para coletas)
  sciVerified       Boolean? @default(false)
  sciVerifiedBy     String?
  sciPopularName    String?
  sciScientificName String?
  sciFamily         String?
  sciEcologicalInfo String?

  author    User       @relation(fields: [authorId], references: [id])
  postLikes PostLike[]
  postSaves PostSave[]
  reports   Report[]
}

model PostLike {
  postId String
  userId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
}

model PostSave {
  postId String
  userId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
}

model Garden {
  id          String   @id @default(cuid())
  name        String
  type        String   // escolar | comunitaria | quintal | telhado
  status      String   @default("ativa") // ativa | implantacao | pausada | arquivada
  school      String
  territory   String
  image       String
  description String
  responsible String
  area        String?
  address     String?
  latitude    Float?
  longitude   Float?
  access      String?  // equipe | comunidade
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  canteiros    Canteiro[]
  participants GardenParticipant[]
  events       Event[]
  cultivoList  GardenCultivo[]
}

model GardenCultivo {
  id       String @id @default(cuid())
  gardenId String
  cultivo  String
  garden   Garden @relation(fields: [gardenId], references: [id], onDelete: Cascade)
}

model Canteiro {
  id             String   @id @default(cuid())
  gardenId       String
  name           String
  fase           String   // preparo | semeadura | crescimento | floracao | colheita
  area           String?
  lastIrrigation String?
  observations   String?
  garden         Garden   @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  cultivoList    CanteiroCultivo[]
}

model CanteiroCultivo {
  id         String   @id @default(cuid())
  canteiroId String
  cultivo    String
  canteiro   Canteiro @relation(fields: [canteiroId], references: [id], onDelete: Cascade)
}

model GardenParticipant {
  gardenId String
  userId   String
  role     String // responsavel | co-responsavel | monitor | participante
  garden   Garden @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([gardenId, userId])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  date        String
  time        String
  endTime     String?
  allDay      Boolean  @default(false)
  location    String
  address     String?
  type        String   // interno | aberto
  category    String   // mutirao | oficina | comunitario | ambiental | reuniao | outros
  description String
  organizerId String
  gardenId    String?
  status      String   @default("ativo") // ativo | encerrado | cancelado
  coverImage  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizer      User            @relation(fields: [organizerId], references: [id])
  garden         Garden?         @relation(fields: [gardenId], references: [id])
  eventInterests EventInterest[]
}

model EventInterest {
  eventId String
  userId  String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
}

model EventSuggestion {
  id               String   @id @default(cuid())
  title            String
  category         String
  suggestedDate    String?
  description      String?
  authorId         String
  status           String   @default("pendente") // pendente | aprovada | rejeitada
  rejectionMessage String?
  createdAt        DateTime @default(now())

  author User @relation(fields: [authorId], references: [id])
}

model UserMedal {
  id         String   @id @default(cuid())
  userId     String
  medalId    String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, medalId])
}

model LeafEntry {
  id        String   @id @default(cuid())
  userId    String
  action    String
  detail    String
  amount    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FoodAnswer {
  id         String   @id @default(cuid())
  userId     String
  questionId Int
  answer     Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
